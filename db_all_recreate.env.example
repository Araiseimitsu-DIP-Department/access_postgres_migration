# db_all_recreate.py 用設定（db_all_recreate.env.example を db_all_recreate.env にコピーして編集）
# ENABLED=false の対象はスキップします
#
# 一括実行時の更新モード（CLI で指定、省略時は --drop-table）:
#   --drop-database  PostgreSQL データベースを DROP 後に再作成
#   --drop-table     public スキーマを DROP 後に再作成（既定）
#   --truncate       テーブル構造を維持しデータのみ更新

# 共通 PostgreSQL 接続（各 TARGET の DATABASE_URL 未指定時に使用）
POSTGRES_HOST=192.168.1.120
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_PASSWORD

LOG_LEVEL=INFO

